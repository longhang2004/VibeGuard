# ==========================================
# GLOBAL ENVIRONMENT SETTINGS
# ==========================================
NODE_ENV=development

# ==========================================
# API GATEWAY SERVICE (Port 3000)
# ==========================================
GATEWAY_PORT=3000
GATEWAY_JWT_SECRET=dev_jwt_access_secret_key_vibeguard_12345
GATEWAY_JWT_REFRESH_SECRET=dev_jwt_refresh_secret_key_vibeguard_67890
GATEWAY_JWT_ACCESS_EXPIRATION=15m
GATEWAY_JWT_REFRESH_EXPIRATION=7d
GATEWAY_DATABASE_URL=postgres://postgres:postgrespassword@localhost:5432/vibeguard
GATEWAY_REDIS_HOST=localhost
GATEWAY_REDIS_PORT=6379

# ==========================================
# CONTEXT SERVICE (Port 3001)
# ==========================================
CONTEXT_PORT=3001
CONTEXT_DATABASE_URL=postgres://postgres:postgrespassword@localhost:5432/vibeguard
CONTEXT_REDIS_HOST=localhost
CONTEXT_REDIS_PORT=6379
CONTEXT_KAFKA_BROKERS=localhost:9092

# ==========================================
# SECURITY SCANNER SERVICE (Port 8080)
# ==========================================
SCANNER_PORT=8080
SCANNER_DATABASE_URL=jdbc:postgresql://localhost:5432/vibeguard
SCANNER_DATABASE_USERNAME=postgres
SCANNER_DATABASE_PASSWORD=postgrespassword
SCANNER_KAFKA_BROKERS=localhost:9092

# ==========================================
# ANALYTICS SERVICE (Port 3002)
# ==========================================
ANALYTICS_PORT=3002
ANALYTICS_DATABASE_URL=postgres://postgres:postgrespassword@localhost:5432/vibeguard
ANALYTICS_KAFKA_BROKERS=localhost:9092

# ==========================================
# NOTIFICATION SERVICE (Port 3003)
# ==========================================
NOTIFICATION_PORT=3003
NOTIFICATION_DATABASE_URL=postgres://postgres:postgrespassword@localhost:5432/vibeguard
NOTIFICATION_KAFKA_BROKERS=localhost:9092
NOTIFICATION_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# ==========================================
# FRONTEND APPLICATION (Port 4000)
# ==========================================
FRONTEND_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:3000
